# ============================================================
# Пример .env файла. Скопируй этот файл как .env и заполни значения.
# НИКОГДА не коммить настоящий .env в git!
# ============================================================

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# MongoDB Connection URI (рекомендуется MongoDB Atlas free tier)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/shopbot?retryWrites=true&w=majority

# Admin Telegram IDs (через запятую, без пробелов)
ADMIN_IDS=123456789

# Реферальный бонус в USDT
REFERRAL_BONUS=0.5

# Минимальная сумма пополнения в USDT
MIN_TOPUP=1

# Товаров на одной странице магазина
ITEMS_PER_PAGE=5

# Валюта по умолчанию для аналитики (USDT / USD / RUB)
DEFAULT_ANALYTICS_CURRENCY=USDT

# Реквизиты для пополнения (показывается пользователю)
TOPUP_WALLET=TYourTRC20WalletAddressHere
TOPUP_NETWORK=TRC-20 (TRON)

# API ключ для BEP-20 (Binance Smart Chain) — https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key

# Bybit API (для автопроверки переводов по UID)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# ============================================================
# Порт для HTTP health-сервера (Render устанавливает автоматически).
# Локально можно оставить пустым — по умолчанию 3000.
# ============================================================
PORT=3000
